class Solution {
public:
        vector<string>result;

        void solve(int open , int close, int n, string temp ){
            if(temp.length()==2*n){
                result.push_back(temp);
                return;
            }
            if(open<n){
                solve(open+1,close,n,temp + "(");
            }

            if(close<open){
                solve(open,close+1,n,temp + ")");
            }
        }
    vector<string> generateParenthesis(int n) {
         solve(0,0,n,"");
        return result;
    }
};