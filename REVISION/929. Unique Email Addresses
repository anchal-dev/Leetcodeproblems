class Solution {
public:
    int numUniqueEmails(vector<string>& emails) {
        unordered_set<string> st;
        
        for (auto email : emails) {
            string local = "", domain = "";
            int i = 0;
            
            while (email[i] != '@') {
                if (email[i] == '+') {
                    while (email[i] != '@') i++;
                    break;
                }
                if (email[i] != '.') {
                    local += email[i];
                }
                i++;
            }
            
            domain = email.substr(i); 
            st.insert(local + domain);
        }
        
        return st.size();
    }
};