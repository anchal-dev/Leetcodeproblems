class Solution {
public:
    int findLucky(vector<int>& arr) {
        unordered_map<int,int>mp;
        for(int num : arr){
            mp[num]++;
        }

        int maxLucky = -1;
        
        for(auto &it : mp){
            if(it.first == it.second){
                maxLucky = max(maxLucky, it.first);
            }
        }
        return maxLucky;

    }
};