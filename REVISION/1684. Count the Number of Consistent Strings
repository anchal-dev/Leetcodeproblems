class Solution {
public:
    int countConsistentStrings(string allowed, vector<string>& words) {
        vector<bool>allowedChars(26, false);

        for(char c : allowed){
            allowedChars[c- 'a'] = true;

        }
        int count =0;
        for(string word:words){
            bool isValid = true;

            for(char  c : word){
            if(!allowedChars[c-'a']){
                isValid = false;
                break;
            }
        }
        if(isValid)count++;
    }
    return count;
    }
};