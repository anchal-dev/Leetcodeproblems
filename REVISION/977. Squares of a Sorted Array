class Solution {
public:
    vector<int> sortedSquares(vector<int>& nums) {
        int n = nums.size();
        vector<int>ans(n);
        int left  = 0,right = n-1,idx =n-1;
        while(left<=right){
            int l = nums[left]*nums[left];
            int r = nums[right]*nums[right];
            if(l<r){
                ans[idx--] =r;
                right--;
            }
            else{
                ans[idx--] = l;
                left++;
            }
        }
        return ans;
    }
};